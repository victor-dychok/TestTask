@model testTask.Models.LogInUserModel


<div class="row">
    <div class="text-lines-container">
        <h3>Вход в аккаунт</h3>
        <form asp-action="Index" method="post" class="form-horizontal">

            <div class="mt-5">
                <label asp-for="Login">Логин</label>
                <div>
                    <input asp-for="Login" class="form-control" />
                    <span asp-validation-for="Login" class="text-danger"></span>
                </div>
            </div>

            <div class="mt-2">
                <label asp-for="Password">Пароль</label>
                <div>
                    <input asp-for="Password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
            </div>

            <input class="btn btn-success mt-3" type="submit" value="Войти" />
        </form>
    </div>
</div>